{
  "name": "engrm",
  "version": "0.4.44",
  "description": "Shared memory across devices, sessions, and agents, with thin MCP tools for durable capture, live continuity, and Hermes-ready remote MCP support",
  "mcpName": "io.github.dr12hes/engrm",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "engrm": "dist/cli.js"
  },
  "files": [
    "dist/",
    "opencode/",
    "packs/",
    "LICENSE"
  ],
  "scripts": {
    "start": "bun run src/server.ts",
    "init": "bun run src/cli.ts init",
    "test": "bun test",
    "build": "bun run bin/build.mjs",
    "check:openclaw-plugin": "node scripts/check-openclaw-plugin-contract.mjs",
    "check:release": "bun run build && node scripts/check-public-docs.mjs && node scripts/check-openclaw-plugin-contract.mjs",
    "prepublishOnly": "npm run check:release"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "engrm",
    "ai-memory",
    "claude-code",
    "mcp",
    "coding-agent",
    "context-injection",
    "sentinel",
    "code-audit",
    "cross-device",
    "team-memory",
    "developer-tools",
    "hermes",
    "streamable-http",
    "remote-mcp"
  ],
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.74",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.6.2",
    "sqlite-vec": "^0.1.7-alpha.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.19",
    "typescript": "^5.8.3"
  },
  "homepage": "https://engrm.dev",
  "bugs": {
    "url": "https://github.com/dr12hes/engrm/issues"
  },
  "license": "FSL-1.1-ALv2",
  "author": "Engrm <hello@engrm.dev> (https://engrm.dev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/dr12hes/engrm.git"
  }
}
